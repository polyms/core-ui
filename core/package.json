{
  "name": "@polyms/core-ui",
  "version": "0.4.9",
  "type": "module",
  "main": "./index.mjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "default": "./index.mjs"
    },
    "./styles/*": "./styles/*",
    "./styles-*.css": "./styles-*.css",
    "./package.json": "./package.json",
    "./*": {
      "types": "./*/index.d.ts",
      "import": "./*/index.mjs",
      "default": "./*/index.mjs"
    }
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  }
}
